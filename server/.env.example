APP_NAME="Atlantis Nexus API"
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1
PORT=4000

BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

DATABASE_URL=postgresql://atlantis:atlantis@localhost:5432/atlantis_nexus

JWT_ACCESS_SECRET=replace-with-a-strong-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=replace-with-another-strong-random-string
JWT_REFRESH_TTL=7d
JWT_REFRESH_COOKIE=atlantis_refresh

SUPERADMIN_EMAIL=owner@example.com
SUPERADMIN_PASSWORD=change-me-on-first-boot
SUPERADMIN_NICKNAME=owner

# Storage: 'local' (writes to STORAGE_LOCAL_ROOT, served at /uploads) or 'r2'.
# When STORAGE_DRIVER=r2 but R2_* envs are missing, the app falls back to local.
STORAGE_DRIVER=local
STORAGE_LOCAL_ROOT=uploads
STORAGE_LOCAL_PUBLIC_BASE=http://localhost:4000/uploads
R2_ACCOUNT_ID=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_URL_BASE=

# Mail driver: 'console' logs verification links to stdout, 'resend' sends via Resend API.
# For 'resend', set RESEND_API_KEY and use a verified MAIL_FROM_ADDRESS
# (use onboarding@resend.dev until you verify your own domain).
MAIL_DRIVER=console
MAIL_FROM_ADDRESS=no-reply@atlantis-nexus.local
MAIL_FROM_NAME="Atlantis Nexus"
RESEND_API_KEY=

# Frontend base URL used to build links inside outgoing emails.
APP_BASE_URL=http://localhost:3000

# Email verification token lifetime. Format: <number><s|m|h|d>.
EMAIL_VERIFICATION_TTL=24h
